<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-06-13T00:00:00.000Z" agent="drawio-chart" version="24.0.0">
  <diagram name="PollingMonitor 轮询循环" id="dda-polling-flow">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="700" pageHeight="900" math="0" shadow="0" background="#F8FAFC">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ===== 标题 ===== -->
        <mxCell id="title" value="&lt;b&gt;PollingMonitor 轮询循环&lt;/b&gt; (500ms 间隔)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=16;fontColor=#2D3748;" vertex="1" parent="1">
          <mxGeometry x="150" y="10" width="400" height="30" as="geometry"/>
        </mxCell>

        <!-- ===== 步骤 1: \alllocks 轮询 ===== -->
        <mxCell id="step-poll" value="&lt;b&gt;1. 轮询锁状态&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;send(&quot;\alllocks&quot;) → recv() → raw_text&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#94A3B8;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=13;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="60" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- 步骤 2: LockParser -->
        <mxCell id="step-parse" value="&lt;b&gt;2. 解析锁状态&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;LockParser.parse(raw_text)&lt;br&gt;→ LockSnapshot&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#E99151;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=13;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="150" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- 步骤 3: WFGBuilder -->
        <mxCell id="step-wfg" value="&lt;b&gt;3. 构造等待图&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;WFGBuilder.build(snapshot)&lt;br&gt;→ WaitForGraph&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#E99151;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=13;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="240" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- 步骤 4: CycleDetector -->
        <mxCell id="step-dfs" value="&lt;b&gt;4. 检测死锁环&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;CycleDetector.detect(wfg)&lt;br&gt;DFS + 三色标记 → [cycle]&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#E99151;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=13;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="330" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- 判断: 有死锁? -->
        <mxCell id="decision-deadlock" value="死锁?" style="rhombus;whiteSpace=wrap;fillColor=#005D7B;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=13;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="420" width="140" height="90" as="geometry"/>
        </mxCell>

        <!-- 无环时 sleep 节点 -->
        <mxCell id="sleep-no-cycle" value="&lt;b&gt;sleep(500ms)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;等待下次轮询&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#94A3B8;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=13;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="435" width="130" height="60" as="geometry"/>
        </mxCell>

        <!-- 步骤 5: VictimSelector -->
        <mxCell id="step-select" value="&lt;b&gt;5. 选定 Victim&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;VictimSelector.select(cycle, snapshot)&lt;br&gt;→ (victim, reason)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#7C3AED;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=13;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="550" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- 步骤 6: RollbackExecutor -->
        <mxCell id="step-kill" value="&lt;b&gt;6. 执行回滚&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;RollbackExecutor.kill(victim)&lt;br&gt;send(&quot;\kill transNum&quot;) → result&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#E99151;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=13;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="640" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- sleep 节点 -->
        <mxCell id="step-sleep" value="&lt;b&gt;sleep(500ms)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px&quot;&gt;等待下次轮询&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#94A3B8;strokeColor=none;fontColor=#FFFFFF;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=13;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="730" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- ===== 组件职责标注 ===== -->
        <mxCell id="label-parser" value="LockParser" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=10;fontColor=#94A3B8;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="480" y="165" width="100" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="label-wfg" value="WFGBuilder" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=10;fontColor=#94A3B8;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="480" y="255" width="100" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="label-cycle" value="CycleDetector" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=10;fontColor=#94A3B8;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="480" y="345" width="100" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="label-select" value="VictimSelector" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=10;fontColor=#94A3B8;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="480" y="565" width="100" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="label-executor" value="RollbackExecutor" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=10;fontColor=#94A3B8;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="480" y="655" width="110" height="20" as="geometry"/>
        </mxCell>

        <!-- ===== 连线 ===== -->

        <!-- 1 → 2 -->
        <mxCell id="edge-1-2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;strokeColor=#94A3B8;" edge="1" source="step-poll" target="step-parse" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 2 → 3 -->
        <mxCell id="edge-2-3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;strokeColor=#94A3B8;" edge="1" source="step-parse" target="step-wfg" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 3 → 4 -->
        <mxCell id="edge-3-4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;strokeColor=#94A3B8;" edge="1" source="step-wfg" target="step-dfs" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 4 → 判断 -->
        <mxCell id="edge-4-decision" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;strokeColor=#94A3B8;" edge="1" source="step-dfs" target="decision-deadlock" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 判断 → 无环 (No) -->
        <mxCell id="edge-no-cycle" value="&lt;b&gt;无环&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;strokeColor=#4CA497;labelBackgroundColor=#F8FAFC;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=12;fontColor=#4CA497;" edge="1" source="decision-deadlock" target="sleep-no-cycle" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- sleep(无环) 循环回到步骤1 -->
        <mxCell id="edge-loop-back-no" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;strokeColor=#94A3B8;dashed=1;" edge="1" source="sleep-no-cycle" target="step-poll" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="680" y="465"/>
              <mxPoint x="680" y="30"/>
              <mxPoint x="350" y="30"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 判断 → VictimSelector (Yes) -->
        <mxCell id="edge-yes-cycle" value="&lt;b&gt;有环&lt;/b&gt;" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;strokeColor=#DC2626;labelBackgroundColor=#F8FAFC;fontFamily=system-ui, -apple-system, PingFang SC, Microsoft YaHei, sans-serif;fontSize=12;fontColor=#DC2626;" edge="1" source="decision-deadlock" target="step-select" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- VictimSelector → RollbackExecutor -->
        <mxCell id="edge-5-6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;strokeColor=#94A3B8;" edge="1" source="step-select" target="step-kill" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- RollbackExecutor → sleep -->
        <mxCell id="edge-6-sleep" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;strokeColor=#94A3B8;" edge="1" source="step-kill" target="step-sleep" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- sleep 循环回到步骤1 -->
        <mxCell id="edge-loop-back" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;strokeWidth=2;strokeColor=#94A3B8;dashed=1;" edge="1" source="step-sleep" target="step-poll" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="200" y="760"/>
              <mxPoint x="200" y="30"/>
              <mxPoint x="350" y="30"/>
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
